# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5502/nudoescudo

# --- Site ---
# Public base URL used in emails (confirmation links).
SITE_URL=http://localhost:3000
# Store display name used in UI and emails.
STORE_NAME=NudoEscudo

# --- Admin ---
# Password for /admin login.
ADMIN_PASSWORD=change-me
# Secret used to sign session cookies and confirmation tokens (long random string).
APP_SECRET=change-me-to-a-long-random-string

# --- Email ---
# 'smtp' (dev: Mailpit), 'resend' (production) or 'console' (log only).
EMAIL_MODE=smtp
EMAIL_FROM="NudoEscudo <pedidos@localhost>"
# Address that receives new-order notifications.
ADMIN_EMAIL=admin@localhost
# smtp mode:
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# resend mode:
RESEND_API_KEY=
